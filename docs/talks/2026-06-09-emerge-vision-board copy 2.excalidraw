    {
      "type": "text",
      "id": "jdl",
      "x": 235.3648448201766,
      "y": 2960.6760342086736,
      "width": 1285,
      "height": 130,
      "text": "架构判断 ·  Agent 平台 = OS 之上的新一层，不是替代 OS（跑在 Linux/macOS/Win 上，用其文件/进程/网络）\n· 别做 App，做能力包      · 编程对 MCP，不对 UI      · 数据当总线，不当私仓（存储即接口）      · 分发/鉴权用平台标准，别自造\n· 护城河迁移：从『占住 UI / 工作流』 →『能力 + 数据纠正闭环（越纠正越准）』 —— UI 锁定已死\n· 时点 ≈ 2008 的 iOS：标准(MCP)刚稳 · marketplace 刚现 · OAuth/DCR 刚标准化 → 早在开放标准上建能力者吃复利\n· 关键差异：App 是确定调用；能力是被概率规划器『选中』调用 → 工具命名 / skill = 对 agent 的『营销』",
      "fontSize": 16,
      "fontFamily": 1,
      "strokeColor": "#92400e",
      "textAlign": "left",
      "verticalAlign": "top",
      "version": 77,
      "versionNonce": 1003571658,
      "index": "bHUj",
      "isDeleted": false,
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "backgroundColor": "transparent",
      "seed": 1,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "boundElements": [],
      "updated": 1781083865786,
      "link": null,
      "locked": false,
      "containerId": null,
      "originalText": "架构判断 ·  Agent 平台 = OS 之上的新一层，不是替代 OS（跑在 Linux/macOS/Win 上，用其文件/进程/网络）\n· 别做 App，做能力包      · 编程对 MCP，不对 UI      · 数据当总线，不当私仓（存储即接口）      · 分发/鉴权用平台标准，别自造\n· 护城河迁移：从『占住 UI / 工作流』 →『能力 + 数据纠正闭环（越纠正越准）』 —— UI 锁定已死\n· 时点 ≈ 2008 的 iOS：标准(MCP)刚稳 · marketplace 刚现 · OAuth/DCR 刚标准化 → 早在开放标准上建能力者吃复利\n· 关键差异：App 是确定调用；能力是被概率规划器『选中』调用 → 工具命名 / skill = 对 agent 的『营销』",
      "autoResize": true,
      "lineHeight": 1.625,
      "customData": {
        "name": "jdl"
      }
    },

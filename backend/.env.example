# Workspace location
EMERGE_WORKSPACE_ROOT=./workspace

# Default models
EMERGE_DEFAULT_EXTRACT_MODEL=gemini-2.5-flash
EMERGE_DEFAULT_AGENT_MODEL=claude-sonnet-4-6
EMERGE_LOG_LEVEL=INFO

# Agent brain (claude_agent_sdk) — read directly by SDK
# When using "claude" config (Max OAuth), set CLAUDE_CODE_OAUTH_TOKEN.
# Either is acceptable; the SDK picks whichever is present.
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_API_KEY=

# Proxy — agent brain vs. extract are intentionally separate
# CLAUDE_PROXY  : SOCKS5/HTTP proxy for the Agent brain (claude_agent_sdk).
#                 Applied as HTTPS_PROXY / HTTP_PROXY at request startup.
CLAUDE_PROXY=
# ANTHROPIC_PROXY / GOOGLE_PROXY : proxy for Extract / Labeler / Proposer adapters.
#   Provider adapters use trust_env=False, so CLAUDE_PROXY is intentionally
#   NOT inherited here — set these independently if extract traffic also needs a proxy.
ANTHROPIC_PROXY=
GOOGLE_PROXY=

# Extract LLM — Google Gemini
# Default surface = AI Studio (generativelanguage). One key, no extra config.
GOOGLE_API_KEY=
#
# ── Vertex AI / "Gemini Enterprise Agent Platform" ───────────────────────────
# Same Gemini models, billed through GCP/Vertex. The flag below turns Vertex ON;
# then ONE of two auth modes runs — picked by whether a Vertex key is present:
#
#   has a Vertex key  → API-KEY express  (no host login; key alone auth)
#   no Vertex key     → ADC              (needs gcloud login on the host)
#
# They do NOT run together — the api key always wins. Only one mode is active.
#
# GOOGLE_GENAI_USE_ENTERPRISE=true   # flag, shared by both modes (alias of
#                                    #   GOOGLE_GENAI_USE_VERTEXAI=true)
#
# (A) API-KEY express — the preferred path:
# GOOGLE_VERTEX_API_KEY=             # the Vertex key (starts with AQ.); selects
#                                    #   express. Falls back to GOOGLE_API_KEY.
# GOOGLE_CLOUD_PROJECT=              # IGNORED here — only ADC uses it (key wins)
# GOOGLE_CLOUD_LOCATION=             # IGNORED here — only ADC uses it (key wins)
#
# (B) ADC (legacy, OCR backfill) — leave the api keys EMPTY, then set:
# GOOGLE_CLOUD_PROJECT=              # required for ADC bearer-token resolution
# GOOGLE_CLOUD_LOCATION=us-east4     # required for ADC

# ── LLM availability monitor (app.monitor) ───────────────────────────────────
# Watchdog that probes each configured provider and alerts via 云之家 (yunzhijia)
# on an availability transition. Fully optional; off unless you set ENABLED=1 or
# start it via POST /lab/monitor/start (or `python -m app.monitor run`).
#
# 云之家 robot webhook (full URL incl. yzjtoken). Empty → probe+log only, no alerts.
EMERGE_ALERT_WEBHOOK_URL=
# EMERGE_ALERT_PROXY=            # optional proxy for the webhook POST
# EMERGE_MONITOR_ENABLED=1       # auto-start the loop on API boot
# EMERGE_MONITOR_INTERVAL=300    # seconds between sweeps
# EMERGE_MONITOR_TIMEOUT=20      # per-probe timeout (a hung provider = down)
# EMERGE_MONITOR_FAIL_THRESHOLD=2  # consecutive fails before alerting (anti-flap)
# EMERGE_MONITOR_REALERT_AFTER=3600  # re-remind if still down this long; 0 = once
# EMERGE_MONITOR_GOOGLE_MODEL=gemini-flash-lite-latest
# EMERGE_MONITOR_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# EMERGE_MONITOR_TARGETS=google,anthropic  # restrict probe set (default: all keyed providers)
# EMERGE_MONITOR_EXCLUDE=google  # subtractive: drop these from the auto set, keep the rest
# NOTE: the anthropic probe routes through ANTHROPIC_BASE_URL ({base}/v1/messages);
#       with no ANTHROPIC_BASE_URL it is skipped (direct api.anthropic.com is forbidden).
# EMERGE_MONITOR_PROBE_AGENT=1   # also probe the Agent brain (spawns the CLI — costly)
# EMERGE_MONITOR_AGENT_INTERVAL=1800  # min seconds between agent-brain probes
# EMERGE_MONITOR_HOST=prod-1     # tag shown in alerts (default: hostname)

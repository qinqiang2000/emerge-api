# Workspace location
EMERGE_WORKSPACE_ROOT=./workspace

# Default models
EMERGE_DEFAULT_EXTRACT_MODEL=gemini-2.5-flash
EMERGE_DEFAULT_AGENT_MODEL=claude-sonnet-4-6
EMERGE_LOG_LEVEL=INFO

# Agent brain (claude_agent_sdk) — read directly by SDK
# When using "claude" config (Max OAuth), set CLAUDE_CODE_OAUTH_TOKEN.
# Either is acceptable; the SDK picks whichever is present.
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_API_KEY=

# Proxy — agent brain vs. extract are intentionally separate
# CLAUDE_PROXY  : SOCKS5/HTTP proxy for the Agent brain (claude_agent_sdk).
#                 Applied as HTTPS_PROXY / HTTP_PROXY at request startup.
CLAUDE_PROXY=
# ANTHROPIC_PROXY / GOOGLE_PROXY : proxy for Extract / Labeler / Proposer adapters.
#   Provider adapters use trust_env=False, so CLAUDE_PROXY is intentionally
#   NOT inherited here — set these independently if extract traffic also needs a proxy.
ANTHROPIC_PROXY=
GOOGLE_PROXY=

# Extract LLM — Google Gemini
GOOGLE_API_KEY=
